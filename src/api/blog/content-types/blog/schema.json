{
  "kind": "collectionType",
  "collectionName": "blogs",
  "info": {
    "singularName": "blog",
    "pluralName": "blogs",
    "displayName": "Blog"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "customField",
      "customField": "plugin::auto-locales-slug.auto-locales-slug",
      "required": true,
      "options": {
        "pattern": "title"
      }
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "description": {
      "type": "text"
    },
    "content": {
      "type": "customField",
      "customField": "plugin::ckeditor.CKEditor",
      "options": {
        "output": "HTML",
        "licenseKey": "eyJhbGciOiJFUzI1NiJ9..F6o2pAUNy75N7_mCHL9ztPdbfK8JQ5BI8JwUDR2Yqf_7zXWKLzPoAOIQ6_-P6NqO2osrW3oDy4SVzzuUJ8bqIQ",
        "preset": "rich"
      }
    },
    "view": {
      "type": "integer",
      "required": false,
      "default": 0
    },
    "seo": {
      "type": "component",
      "component": "seo.seo",
      "repeatable": false
    }
  }
}
